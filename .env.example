# Copy to .env and fill in. .env is gitignored — NEVER commit it.
#
# Source from a shell with:
#   set -a; source .env; set +a
# This exports every assignment to subprocesses so the CLI sees them.

# Sentry token (same scope as the GHA secret SENTRY_TOKEN). Required for
# `python src/run.py get` and scripts/export_daily_parquet.py-style fetches.
SENTRY_TOKEN=

# micromamba environment to use for any local CLI invocation.
MICROMAMBA_ENV=fmriprep-stats

# Optional — only needed if running the Dropbox sync scripts locally
# (scripts/upload_dropbox.py, scripts/dropbox_parquet_sync.py,
# scripts/dropbox_upload_plots.py). The daily/weekly GHA workflows
# read these from repo secrets, so leaving them blank is fine for
# token-only Sentry work.
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=
# DROPBOX_APP_REFRESH_TOKEN=
# DROPBOX_PARQUET_PATH=
# DROPBOX_PLOTS_PATH=

# Opt-in to MongoDB reads/writes. Leave unset for the parquet-first path.
# FMRIPREP_STATS_ENABLE_MONGO=1
